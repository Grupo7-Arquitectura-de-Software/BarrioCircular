DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest
FRONTEND_PORT=80

SUPABASE_DB_URL=jdbc:postgresql://your-project.pooler.supabase.com:5432/postgres
SUPABASE_DB_USERNAME=your-supabase-username
SUPABASE_DB_PASSWORD=replace-with-a-secure-password
DB_MAX_POOL_SIZE=3
DB_MIN_IDLE=0

CLERK_JWKS_URI=https://your-clerk-domain/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain
FRONTEND_BASE_URL=https://barriocircular.site
CORS_ALLOWED_ORIGINS=https://www.barriocircular.site,https://barriocircular.site

VITE_CLERK_PUBLISHABLE_KEY=replace-with-your-clerk-publishable-key
# Nginx resuelve /api hacia el backend interno.
VITE_API_BASE_URL=/api
