# cp .env.example .env

# Supabase (PostgreSQL - Session Pooler)
SUPABASE_DB_URL=jdbc:postgresql://<host>:<port>/postgres
SUPABASE_DB_USERNAME=postgres.<project-id>
SUPABASE_DB_PASSWORD=<tu-password>

# Clerk
CLERK_JWKS_URI=https://<tu-dominio>/.well-known/jwks.json
CLERK_ISSUER=https://<tu-dominio>.accounts.dev

# GroQ (Sugerencia de Precio con IA)
GROQ_API_KEY=<tu-api-key-de-groq>
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
